# RabbitMQ (docker compose)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=jaum
RABBITMQ_PASSWORD=jaum
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://jaum:jaum@localhost:5672/

# Filas
RABBITMQ_QUEUE_PROCESSING=diagram_processing
RABBITMQ_QUEUE_REPORT=diagram_report

# Serviços (preencher conforme implementação)
PORT=3000
# upload-service (SQLite local)
UPLOAD_DATABASE_URL=file:./upload-service/dev.db
GEMINI_API_KEY=
